# If you come from bash you might have to change your $PATH.
export PATH=$HOME/bin:$HOME/.local/bin:/usr/local/bin:$PATH

# User configuration
export LANG=pl_PL.UTF-8

# Preferred editor for local and remote sessions
if [[ -n $SSH_CONNECTION ]]; then
  export EDITOR='nvim'
else
  export EDITOR='nvim'
fi

# Add ~/scripts to PATH
export PATH="$HOME/scripts:$PATH"

# Example aliases
alias zshconfig="nvim ~/.zshrc"
alias ohmyzsh="nvim ~/.oh-my-zsh"

# Alias yay to use the safe wrapper
alias yay="yay-safe.sh"
alias ls="eza --icons"

# k3s
alias k="kubectl"
alias kdash="kubectl -n kubernetes-dashboard create token admin-user --duration=3h"

## fzf
# cd into a directory
alias c='cd "$(fd --type d | fzf)" || return'

# open file in nvim
alias f='nvim $(fd --type f | fzf)'

# open file with preview
alias fp='nvim "$(fd --type f | fzf --preview "bat --style=numbers --color=always {}")"'

# serach inside files
alias fs='rg --line-number "" | fzf'

# stforge project
alias sfc='~/stforge.sh client'
alias sfs='~/stforge.sh server'
alias sfr='~/stforge.sh root'

# eza colors
export LS_COLORS="$(vivid generate catppuccin-mocha)"

# rofi launcher
export PATH="$HOME/.config/rofi/scripts:$PATH"

# browser
export BROWSER="brave"
export CHROME_PATH="/usr/bin/brave"
export EDGE_PATH="/usr/bin/brave"

export PATH="$HOME/.local/bin:$PATH"
export PATH="$PATH:/usr/bin/npm"
export npm_config_prefix="$HOME/.local"

# golang
export PATH="$PATH:$(go env GOBIN):$(go env GOPATH)/bin"
export PATH="$PATH:/home/dave/go/bin"

# android
export ANDROID_HOME="$HOME/Android/Sdk"
export PATH="$PATH:$ANDROID_HOME/emulator"
export PATH="$PATH:$ANDROID_HOME/platform-tools"

# set TERM colors used by alacritty and other plugins
export TERM=screen-256color

# run Electron/Chromium apps on Wayland
export ELECTRON_OZONE_PLATFORM_HINT=wayland

# specifically for Electron apps
export ELECTRON_ENABLE_WAYLAND=1

# fzf integration
source /usr/share/fzf/key-bindings.zsh
source /usr/share/fzf/completion.zsh

eval "$(starship init zsh)"
